      "source": [
        "# Program to read assembly instructions with addresses\n",
        "# and generate a symbol table\n",
        "\n",
        "def generate_symbol_table():\n",
        "    # Dictionary to store symbol table\n",
        "    symbol_table = {}\n",
        "\n",
        "    # Take number of lines as input\n",
        "    n = int(input(\"Enter number of assembly instructions: \"))\n",
        "\n",
        "    print(\"\\nEnter assembly instructions in format:\")\n",
        "    print(\"ADDRESS LABEL: INSTRUCTION\")\n",
        "    print(\"Example: 100 START: MOV A, B\\n\")\n",
        "\n",
        "    # Loop to read each line\n",
        "    for i in range(n):\n",
        "        line = input(f\"Line {i+1}: \")\n",
        "\n",
        "        # Split address and rest of instruction\n",
        "        parts = line.strip().split(maxsplit=1)\n",
        "\n",
        "        # Check if address is present\n",
        "        if len(parts) < 2:\n",
        "            print(\"Invalid format! Skipping line.\")\n",
        "            continue\n",
        "\n",
        "        address = parts[0]\n",
        "        rest = parts[1]\n",
        "\n",
        "        # Check if label exists (LABEL:)\n",
        "        words = rest.split()\n",
        "\n",
        "        if len(words) > 0 and words[0].endswith(\":\"):\n",
        "            # Remove ':' from label\n",
        "            label = words[0][:-1]\n",
        "\n",
        "            # Store in symbol table\n",
        "            symbol_table[label] = int(address)\n",
        "\n",
        "    # Display Symbol Table\n",
        "    print(\"\\nGenerated Symbol Table:\")\n",
        "    print(\"------------------------\")\n",
        "    print(\"Symbol\\tAddress\")\n",
        "    print(\"------------------------\")\n",
        "\n",
        "    for symbol in symbol_table:\n",
        "        print(symbol, \"\\t\", symbol_table[symbol])\n",
        "\n",
        "\n",
        "# Run the program\n",
        "generate_symbol_table()"
      ]
    },
