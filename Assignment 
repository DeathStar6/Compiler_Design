      "source": [
        "def simulate_LC(code):\n",
        "    LC = 0  # Location Counter\n",
        "\n",
        "    for line in code:\n",
        "        parts = line.strip().split()\n",
        "\n",
        "        # Handle START directive\n",
        "        if parts[0] == \"START\":\n",
        "            LC = int(parts[1])\n",
        "            print(f\"{LC} -> {line}\")\n",
        "\n",
        "        # Handle label (LABEL:)\n",
        "        elif parts[0].endswith(\":\"):\n",
        "            print(f\"{LC} -> {line}\")\n",
        "            LC += 4   # instruction size\n",
        "\n",
        "        # Handle DS (Define Storage)\n",
        "        elif \"DS\" in parts:\n",
        "            print(f\"{LC} -> {line}\")\n",
        "            LC += int(parts[-1])  # allocate memory\n",
        "\n",
        "        # Handle DC (Define Constant)\n",
        "        elif \"DC\" in parts:\n",
        "            print(f\"{LC} -> {line}\")\n",
        "            LC += 4   # assume constant = 4 bytes\n",
        "\n",
        "        # Handle END\n",
        "        elif parts[0] == \"END\":\n",
        "            print(f\"{LC} -> {line}\")\n",
        "            break\n",
        "\n",
        "        # Normal instruction\n",
        "        else:\n",
        "            print(f\"{LC} -> {line}\")\n",
        "            LC += 4   # assume each instruction = 4 bytes\n",
        "\n",
        "\n",
        "# Sample Assembly Code\n",
        "assembly_code = [\n",
        "    \"START 100\",\n",
        "    \"LOOP: MOVER AREG, B\",\n",
        "    \"ADD AREG, C\",\n",
        "    \"VAR DS 2\",\n",
        "    \"CONST DC 5\",\n",
        "    \"JMP LOOP\",\n",
        "    \"END\"\n",
        "]\n",
        "\n",
        "simulate_LC(assembly_code)"
      ],
